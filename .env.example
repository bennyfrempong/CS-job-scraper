# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pipeline_user:pipeline_pass@localhost:5432/jobpipeline

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Optional API Keys ─────────────────────────────────────────────────────────
# Scrapers skip gracefully if keys are not set.

# Adzuna — free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# The Muse — optional free key at https://www.themuse.com/developers/api/v2
THE_MUSE_API_KEY=

# USAJobs — free key at https://developer.usajobs.gov/
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# ─── GitHub ────────────────────────────────────────────────────────────────────
# Optional — raises SimplifyJobs scraper rate limit from 60 → 5000 req/hr.
# Generate at https://github.com/settings/tokens (no special scopes needed)
GITHUB_TOKEN=

# ─── Scraping Behaviour ────────────────────────────────────────────────────────
REQUEST_DELAY_SECONDS=1.0
MAX_RETRIES=3
LOG_LEVEL=INFO
